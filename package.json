    "type": "module",
    "scripts": {
        "build": "tsc && tsc-alias",
        "start": "node dist/index.js",
        "bun": "bun run src/index.ts"
    },
    "dependencies": {
        "@wxn0brp/db-client": "^0.110.0",
        "@wxn0brp/db-core": "^0.11.0",
        "@wxn0brp/falcon-frame": "^0.8.2"
