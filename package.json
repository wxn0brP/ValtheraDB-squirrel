{
    "name": "@wxn0brp/db-squirrel",
    "version": "0.0.1",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "description": "",
    "repository": {
        "type": "git",
        "url": "https://github.com/wxn0brP/ValtheraDB-squirrel.git"
    },
    "homepage": "https://github.com/wxn0brP/ValtheraDB-squirrel",
    "author": "wxn0brP",
